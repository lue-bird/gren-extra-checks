module Main exposing (main)

import DebugIsNotUsed
import StringSpellsCompanyNameCorrectly
import ExtraChecksRunnerNode


main =
    ExtraChecksRunnerNode.program
        { extraPaths = [ "README.md" ]
        , checks =
            [ DebugIsNotUsed.check
            , StringSpellsCompanyNameCorrectly.check
            ]
        }
