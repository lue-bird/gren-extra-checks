module Tests exposing (tests)

import ExtraCheck
import DebugIsNotUsed
import StringSpellsCompanyNameCorrectly
import DocumentationDoesNotContainTodo
import Test
import Expect
import Test.Runner
import Random


tests : Test.Test
tests =
    Test.describe "gren-extra-checks"
        [ Test.describe "DebugIsNotUsed"
            [ Test.test "fully qualified Debug.log from implicit import"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "Debug.log is used"
                              , details =
                                    """
                                    Debug.log is a quick and dirty way to display a value in the console
                                    and can for example be used to inspect private (opaque) types.
                                    It's nothing a published product should make use of.
                                    Using any `Debug` member also prevents compiling in optimized mode and publishing as a package.
                                    """
                              , region = ExtraCheck.ExpectUnder "Debug.log"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "fully qualified Debug.log from explicit import"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Debug
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "Debug.log is used"
                              , details =
                                    """
                                    Debug.log is a quick and dirty way to display a value in the console
                                    and can for example be used to inspect private (opaque) types.
                                    It's nothing a published product should make use of.
                                    Using any `Debug` member also prevents compiling in optimized mode and publishing as a package.
                                    """
                              , region = ExtraCheck.ExpectUnder "Debug.log"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "qualified Debug.log using import alias"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Debug as Dbg
                                a = Dbg.log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "Debug.log is used"
                              , details =
                                    """
                                    Debug.log is a quick and dirty way to display a value in the console
                                    and can for example be used to inspect private (opaque) types.
                                    It's nothing a published product should make use of.
                                    Using any `Debug` member also prevents compiling in optimized mode and publishing as a package.
                                    """
                              , region = ExtraCheck.ExpectUnder "Dbg.log"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "Debug.log where Debug points to a different module"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Stream.Log as Debug
                                import Debug as Dbg
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "unqualified Debug.log using explicit import expose"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Debug exposing (log)
                                a = log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "Debug.log is used"
                              , details =
                                    """
                                    Debug.log is a quick and dirty way to display a value in the console
                                    and can for example be used to inspect private (opaque) types.
                                    It's nothing a published product should make use of.
                                    Using any `Debug` member also prevents compiling in optimized mode and publishing as a package.
                                    """
                              , region =
                                    ExtraCheck.ExpectUnderExactly
                                        { section = "log", startingAt = { row = 3, col = 5 } }
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "unqualified log referring to module-level variable, not explicit import expose"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Debug exposing (log)
                                a = log "·u·"
                                log = Basics.identity
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "unqualified log referring to local variable, not explicit import expose"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Debug exposing (log)
                                a log = log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            ]
        , Test.describe "DocumentationDoesNotContainTodo"
            [ Test.test "in -- comment"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                -- TODO
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
            , -- TODO it seems this string is trimmed,
              -- so regions might be inaccurate.
              -- to offset this, we can for example
              -- recover the trimmed whitespace by
              -- checking the comment position in the
              -- source code
              Test.test "in --  comment with extra initial whitespace"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                --  TODO
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
                |> Test.skip
            , Test.test "in {- comment -}"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                {- TODO -}
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "in {-  comment -} with extra initial whitespace"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
