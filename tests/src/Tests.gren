expectExpectationFail : Expect.Expectation -> Expect.Expectation
expectExpectationFail expectationToCheck =
    when expectationToCheck |> Test.Runner.getFailureReason is
        Nothing ->
            Expect.fail "expected Expect.fail _"
        Just failure ->
            Expect.pass
