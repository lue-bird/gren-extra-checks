module Tests exposing (tests)

import ExtraCheck
import DebugIsNotUsed
import StringSpellsCompanyNameCorrectly
import DocumentationDoesNotContainTodo
import Test
import Expect
import Test.Runner
import Random
import IntroducedNameIsUsed


tests : Test.Test
tests =
    Test.describe "gren-extra-checks"
        [ Test.describe "DebugIsNotUsed"
            [ Test.test "fully qualified Debug.log from implicit import"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "Debug.log is used"
                              , details =
                                    """
                                    Debug.log is a quick and dirty way to display a value in the console
                                    and can for example be used to inspect private (opaque) types.
                                    It's nothing a published product should make use of.
                                    Using any `Debug` member also prevents compiling in optimized mode and publishing as a package.
                                    """
                              , region = ExtraCheck.ExpectUnder "Debug.log"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "fully qualified Debug.log from explicit import"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Debug
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "Debug.log is used"
                              , details =
                                    """
                                    Debug.log is a quick and dirty way to display a value in the console
                                    and can for example be used to inspect private (opaque) types.
                                    It's nothing a published product should make use of.
                                    Using any `Debug` member also prevents compiling in optimized mode and publishing as a package.
                                    """
                              , region = ExtraCheck.ExpectUnder "Debug.log"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "qualified Debug.log using import alias"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Debug as Dbg
                                a = Dbg.log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "Debug.log is used"
                              , details =
                                    """
                                    Debug.log is a quick and dirty way to display a value in the console
                                    and can for example be used to inspect private (opaque) types.
                                    It's nothing a published product should make use of.
                                    Using any `Debug` member also prevents compiling in optimized mode and publishing as a package.
                                    """
                              , region = ExtraCheck.ExpectUnder "Dbg.log"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "Debug.log where Debug points to a different module"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Stream.Log as Debug
                                import Debug as Dbg
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "unqualified Debug.log using explicit import expose"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Debug exposing (log)
                                a = log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "Debug.log is used"
                              , details =
                                    """
                                    Debug.log is a quick and dirty way to display a value in the console
                                    and can for example be used to inspect private (opaque) types.
                                    It's nothing a published product should make use of.
                                    Using any `Debug` member also prevents compiling in optimized mode and publishing as a package.
                                    """
                              , region =
                                    ExtraCheck.ExpectUnderExactly
                                        { section = "log", startingAt = { row = 3, col = 5 } }
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "unqualified log referring to module-level variable, not explicit import expose"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Debug exposing (log)
                                a = log "·u·"
                                log = Basics.identity
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "unqualified log referring to local variable, not explicit import expose"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                import Debug exposing (log)
                                a log = log "·u·"
                                """
                          }
                        ]
                    , check = DebugIsNotUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            ]
        , Test.describe "DocumentationDoesNotContainTodo"
            [ Test.test "in -- comment"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                -- TODO
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
            , -- TODO it seems this string is trimmed,
              -- so regions might be inaccurate.
              -- to offset this, we can for example
              -- recover the trimmed whitespace by
              -- checking the comment position in the
              -- source code
              Test.test "in --  comment with extra initial whitespace"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                --  TODO
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
                |> Test.skip
            , Test.test "in {- comment -}"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                {- TODO -}
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "in {-  comment -} with extra initial whitespace"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                {-  TODO -}
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
                |> Test.skip
            , Test.test "in {-| module doc comment -}"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                {-| TODO -}
                                --
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "in {-| variable module declaration doc comment -}"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (a)
                                {-| -}
                                {-| TODO -}
                                a = Debug.log "·u·"
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "in {-| type alias module declaration doc comment -}"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (Str)
                                {-| -}
                                {-| TODO -}
                                type alias Str = String
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "in {-| choice type module declaration doc comment -}"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (Blank)
                                {-| -}
                                {-| TODO -}
                                type Blank = Blank
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
            , Test.test "in {-| port module declaration doc comment -}"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                port module A exposing (a)
                                {-| -}
                                {-| TODO -}
                                port a : String -> Cmd event 
                                """
                          }
                        ]
                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
                              , fixedFiles = []
                              }
                            ]
                )
            ]
        , Test.describe "IntroducedNameIsUsed"
            [ Test.test "pattern variable from module declaration parameter"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (main)
                                main { inner = unusedParameter } =
                                    { inner = "" }
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "pattern variable unusedParameter is never referenced"
                              , details =
                                    "Use this variable or prepend an underscore to explicitly ignore it."
                              , region = ExtraCheck.ExpectUnder "unusedParameter"
                              , fixedFiles =
                                    [ { path = "src/A.gren"
                                      , source =
                                            """
                                            module A exposing (main)
                                            main { inner = _unusedParameter } =
                                                { inner = "" }
                                            """
                                      }
                                    ]
                              }
                            ]
                )
            , Test.test "pattern variable from module declaration parameter is used"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (main)
                                main { inner = usedParameter } =
                                    { inner = usedParameter }
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "pattern variable from when is unqualified variant case pattern is used"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (main)
                                main =
                                    when maybe is
                                        Just line -> line.string
                                        Nothing -> ""
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "punned field pattern"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (main)
                                main { unusedParameter } =
                                    { inner = "" }
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "punned pattern field unusedParameter is never referenced"
                              , details =
                                    "Use this variable or append = _ to explicitly ignore it."
                              , region = ExtraCheck.ExpectUnder "unusedParameter"
                              , fixedFiles =
                                    [ { path = "src/A.gren"
                                      , source =
                                            """
                                            module A exposing (main)
                                            main { unusedParameter = _ } =
                                                { inner = "" }
                                            """
                                      }
                                    ]
                              }
                            ]
                )
            , Test.test "let-defined variable"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (main)
                                main =
                                    let
                                        inner = unusedParameter
                                    in
                                    { result = "" }
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "let-defined variable inner is never referenced"
                              , details =
                                    "Use this variable or remove the let define. Alternatively, if you want to keep a value around for debugging, assign it to _ to explicitly ignore it."
                              , region = ExtraCheck.ExpectUnder "inner"
                              , fixedFiles =
                                    [ { path = "src/A.gren"
                                      , source =
                                            """
                                            module A exposing (main)
                                            main =
                                                { result = "" }
                                            """
                                      }
                                    ]
                              }
                            ]
                )
            , Test.test "module-defined variable"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (main)
                                main = ""
                                unusedVariable = ""
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "A.unusedVariable is never referenced"
                              , details =
                                    "Use it or remove it along with potential exposes. If you think you may still need something like it sometime in the distant future, keep it around in a file outside this gren project."
                              , region = ExtraCheck.ExpectUnder "unusedVariable"
                              , fixedFiles =
                                    [ { path = "src/A.gren"
                                      , source =
                                            """
                                            module A exposing (main)
                                            main = ""

                                            """
                                      }
                                    ]
                              }
                            ]
                )
            , Test.test "module-defined variable is used"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (main)
                                main = usedVariable
                                usedVariable = ""
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "module-defined variable is used only in other module via explicit import expose"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (usedVariable)
                                usedVariable = ""
                                """
                          }
                        , { path = "src/B.gren"
                          , source =
                                """
                                module B exposing (main)
                                import A exposing (usedVariable)
                                main = usedVariable
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "module-defined variable is used only in other module via explicit import, fully qualified"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (usedVariable)
                                usedVariable = ""
                                """
                          }
                        , { path = "src/B.gren"
                          , source =
                                """
                                module B exposing (main)
                                import A
                                main = A.usedVariable
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "module-defined variable is used only in other module via explicit import, qualified with alias"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (usedVariable)
                                usedVariable = ""
                                """
                          }
                        , { path = "src/B.gren"
                          , source =
                                """
                                module B exposing (main)
                                import A as Alias
                                main = Alias.usedVariable
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "module-defined variable is used only in other module via explicit import exposing (..)"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (usedVariable)
                                usedVariable = ""
                                """
                          }
                        , { path = "src/B.gren"
                          , source =
                                """
                                module B exposing (main)
                                import A exposing (..)
                                main = usedVariable
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "module-defined variable not used even though it is explicitly imported exposing (..)"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (something, unusedVariable)
                                unusedVariable = ""
                                something = ""
                                """
                          }
                        , { path = "src/B.gren"
                          , source =
                                """
                                module B exposing (main)
                                import A exposing (..)
                                main = something
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "A.unusedVariable is never referenced"
                              , details =
                                    "Use it or remove it along with potential exposes. If you think you may still need something like it sometime in the distant future, keep it around in a file outside this gren project."
                              , region =
                                    ExtraCheck.ExpectUnderExactly
                                        { section = "unusedVariable", startingAt = { row = 2, col = 1 } }
                              , fixedFiles =
                                    [ { path = "src/A.gren"
                                      , source =
                                            """
                                            module A exposing (something)

                                            something = ""
                                            """
                                      }
                                    ]
                              }
                            ]
                )
            , Test.test "unused variable fix removes explicit import expose, only one expose"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (something, unusedVariable)
                                unusedVariable = ""
                                something = ""
                                """
                          }
                        , { path = "src/B.gren"
                          , source =
                                """
                                module B exposing (main)
                                import A exposing (unusedVariable)
                                main = A.something
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "A.unusedVariable is never referenced"
                              , details =
                                    "Use it or remove it along with potential exposes. If you think you may still need something like it sometime in the distant future, keep it around in a file outside this gren project."
                              , region =
                                    ExtraCheck.ExpectUnderExactly
                                        { section = "unusedVariable", startingAt = { row = 2, col = 1 } }
                              , fixedFiles =
                                    [ { path = "src/A.gren"
                                      , source =
                                            """
                                            module A exposing (something)
                                            
                                            something = ""
                                            """
                                      }
                                    , { path = "src/B.gren"
                                      , source =
                                            """
                                            module B exposing (main)
                                            import A
                                            main = A.something
                                            """
                                      }
                                    ]
                              }
                            ]
                )
            , Test.test "port"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                port module A exposing (main)
                                main = ""
                                port send : Cmd event
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "A.send is never referenced"
                              , details =
                                    "Use it or remove it along with potential exposes. If you think you may still need something like it sometime in the distant future, keep it around in a file outside this gren project."
                              , region = ExtraCheck.ExpectUnder "send"
                              , fixedFiles =
                                    [ { path = "src/A.gren"
                                      , source =
                                            """
                                            module A exposing (main)
                                            main = ""

                                            """
                                      }
                                    ]
                              }
                            ]
                )
            , Test.test "port is used"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                port module A exposing (main)
                                main = send
                                port send : Cmd event
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "module-defined type alias is used"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
                    , files =
                        [ { path = "src/A.gren"
                          , source =
                                """
                                module A exposing (main)
                                main : Used
                                main = ""
                                type alias Used = String
                                """
                          }
                        ]
                    , check = IntroducedNameIsUsed.check
                    }
                        |> ExtraCheck.expectToReport []
                )
            , Test.test "module-defined type alias"
                (\{} ->
                    { projectConfiguration = ExtraCheck.applicationConfigurationMinimal
