                    , check = DocumentationDoesNotContainTodo.check [ "TODO" ]
                    }
                        |> ExtraCheck.expectToReport
                            [ { path = "src/A.gren"
                              , message = "marked TODO"
                              , details =
                                    "This TODO has been placed here as a reminder. Read the comment and analyze the surrounding context to decide what needs to be done. Once the issue is resolved, remove the notice."
                              , region = ExtraCheck.ExpectUnder "TODO"
