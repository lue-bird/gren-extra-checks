                              , details = "The typo of using frits.com instead of fruits.com has been made and noticed by users too many times. Our company is `fruits.com`, not `frits.com`."
                              , region = ExtraCheck.ExpectUnder "frits.com"
                              , fixedFiles =
                                    [ { path = "src/A.gren"
                                      , source = """
